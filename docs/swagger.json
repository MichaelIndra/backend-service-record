                        }
                    }
                }
            },
            "post": {
                "description": "Simpan header transaksi beserta banyak detail service dan sparepart sekaligus.",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Transaction"
                ],
                "summary": "Simpan Transaksi Lengkap",
                "parameters": [
                    {
                        "type": "string",
                        "description": "No Polisi Kendaraan",
                        "name": "no_polisi",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "ID Bengkel",
                        "name": "bengkel_id",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "number",
                        "description": "Total Biaya (Bruto)",
                        "name": "biaya_bruto",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "number",
                        "description": "Total Diskon",
                        "name": "diskon",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "number",
                        "description": "Total Bayar (Netto)",
                        "name": "biaya_netto",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Format: 2006-01-02",
                        "name": "tanggal_transaksi",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Format: 2006-01-02",
                        "name": "tanggal_masuk",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Format: 2006-01-02",
                        "name": "tanggal_selesai",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Kilometer Kendaraan",
                        "name": "km",
                        "in": "formData"
                    },
                    {
                        "type": "string",
                        "description": "Nomor Nota Manual",
                        "name": "no_nota",
                        "in": "formData"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "file"
                        },
                        "collectionFormat": "multi",
                        "description": "Foto Nota Utama (Bisa upload lebih dari 1 foto)",
                        "name": "foto_nota[]",
                        "in": "formData"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "collectionFormat": "multi",
                        "description": "Daftar Nama Service",
                        "name": "service_name[]",
                        "in": "formData"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "number"
                        },
                        "collectionFormat": "multi",
                        "description": "Daftar Harga Service",
                        "name": "service_price[]",
                        "in": "formData"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "file"
                        },
                        "collectionFormat": "multi",
                        "description": "Daftar Foto Service",
                        "name": "foto_service[]",
                        "in": "formData"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "collectionFormat": "multi",
                        "description": "Daftar Nama Sparepart",
                        "name": "sparepart_name[]",
                        "in": "formData"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "collectionFormat": "multi",
                        "description": "Daftar Kode Sparepart",
                        "name": "sparepart_code[]",
                        "in": "formData"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "number"
                        },
                        "collectionFormat": "multi",
                        "description": "Daftar Harga Sparepart",
                        "name": "sparepart_price[]",
                        "in": "formData"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "collectionFormat": "multi",
                        "description": "Daftar Batas KM Sparepart",
                        "name": "sparepart_batas_km[]",
                        "in": "formData"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "collectionFormat": "multi",
                        "description": "Daftar Batas Waktu Sparepart",
                        "name": "sparepart_batas_waktu[]",
                        "in": "formData"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "boolean"
                        },
                        "collectionFormat": "multi",
                        "description": "Daftar Remind Sparepart",
                        "name": "sparepart_remind[]",
                        "in": "formData"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "number"
                        },
                        "collectionFormat": "multi",
                        "description": "Daftar Qty Sparepart",
                        "name": "sparepart_qty[]",
                        "in": "formData"
                    },
                    {
                        "type": "array",
                        "items": {
                            "type": "file"
                        },
                        "collectionFormat": "multi",
                        "description": "Daftar Foto Sparepart",
                        "name": "foto_sparepart[]",
                        "in": "formData"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Transaction"
                        }
                    }
                }
            }
        },
